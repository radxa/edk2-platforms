  # Selection of the display interface.
  #   PcdDisplayEnable      - enable display, default enabled
  #   PcdDisplayInterface   - default display interface, 0=eDP, 1=DP
  #   PcdDisplayI2CBaseAddr - Base address of the I2C block used for cummunication with display
  #   PcdDisplayReadEDID    - True = read EDID from display if available. If not available, set fixed resolution (default 1920x1080@60)
  #                           False = skip EDID reading (even if available) and set fixed resolution (default 1920x1080@60)
  gCixTokenSpaceGuid.PcdDisplayEnable|TRUE|BOOLEAN|0x00000027
  gCixTokenSpaceGuid.PcdDisplayI2CBaseAddr|0x30A30000|UINT32|0x0000002A
  gCixTokenSpaceGuid.PcdDisplayReadEDID|TRUE|BOOLEAN|0x0000002B

