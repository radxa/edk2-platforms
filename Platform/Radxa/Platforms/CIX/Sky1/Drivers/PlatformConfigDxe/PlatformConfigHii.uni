#langdef en-US  "English"

#string STR_FORM_SET_TITLE              #language en-US "Platform Configuration"
#string STR_FORM_SET_TITLE_HELP         #language en-US "Press <Enter> to configure platform settings."

#string STR_MAIN_FORM_TITLE             #language en-US "Platform Configuration"
#string STR_EMPTY_STRING                #language en-US ""
#string STR_EXIT_STRING                 #language en-US  "Press ESC to exit."

#string STR_ENABLED                     #language en-US "Enabled"
#string STR_DISABLED                    #language en-US "Disabled"

