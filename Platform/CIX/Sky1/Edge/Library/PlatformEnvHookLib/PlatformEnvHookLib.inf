[Defines]
  INF_VERSION                    = 0x0001001A
  BASE_NAME                      = PlatformEnvHookLib
  FILE_GUID                      = C6059DC8-B686-4286-A945-E2470E5EF54F
  MODULE_TYPE                    = DXE_DRIVER
  VERSION_STRING                 = 1.0
  LIBRARY_CLASS                  = PlatformEnvHookLib|DXE_DRIVER DXE_RUNTIME_DRIVER UEFI_APPLICATION UEFI_DRIVER
  CONSTRUCTOR                    = PlatformEnvHookLibConstructor

[Sources.common]
  PlatformEnvHookLib.c

[Packages]
  ArmPkg/ArmPkg.dec
  EmbeddedPkg/EmbeddedPkg.dec
  MdePkg/MdePkg.dec
  Platform/CIX/Sky1/Sky1.dec
  Silicon/CIX/Sky1/CixPkg.dec
  NetworkPkg/NetworkPkg.dec

[LibraryClasses]
  BaseMemoryLib
  MemoryAllocationLib
  DebugLib
  BaseLib
  UefiBootServicesTableLib
  UefiRuntimeServicesTableLib
  UefiLib
  PinMuxLib
  PinMuxTableLib
  GpioLib
  GpioTableLib
  CixSipLib
  EcLib
  MailBoxLib
  CixFwBootPerfLib
  PostCodeLib
  CixGPNVLib
  IoLib

[Guids]
  gCixI2cDevicePathGuid
  gEfiNetworkStackSetupGuid
  gPlatformSetupVariableGuid
  gEfiEventReadyToBootGuid
  gCixGPNVGuid
  gCixFarmEnableFlagGuid

[Protocols]
  gEfiI2cMasterProtocolGuid
  gEfiDevicePathProtocolGuid
