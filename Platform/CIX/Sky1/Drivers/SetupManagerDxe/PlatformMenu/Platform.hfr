      endoneof;

      oneof varid   = PlatformSetupVar.IspCamera2Power,
        prompt      = STRING_TOKEN(STR_ISP_CAMERA2_PROMPT),
        help        = STRING_TOKEN(STR_ISP_CAMERA2_PROMPT_HELP),
        default     = FixedPcdGet16 (PcdIspCamera2Power),
        option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
