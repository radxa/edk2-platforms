    form formid = PLATFORM_FORM_SET_ID,
      title  = STRING_TOKEN(STR_PLATFORM_FORM_SET_TITLE);
      subtitle text = STRING_TOKEN(STR_EMPTY_STRING);

      oneof varid   = NetworkStackVar.Enable,
        prompt      = STRING_TOKEN(STR_NETWORK_STACK_PROMPT),
        help        = STRING_TOKEN(STR_NETWORK_STACK_PROMPT_HELP),
        default     = FixedPcdGet8 (PcdNetworkStackSupport),
        option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_ENABLED),  value = 1, flags = RESET_REQUIRED;
      endoneof;
suppressif ideqval NetworkStackVar.Enable == 0x0;
      oneof varid   = NetworkStackVar.Ipv4Pxe,
        prompt      = STRING_TOKEN(STR_IPV4_PXE_BOOT_PROMPT),
        help        = STRING_TOKEN(STR_IPV4_PXE_BOOT_PROMPT_HELP),
        default     = FixedPcdGet8 (PcdIPv4PXESupport),
        option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_ENABLED),  value = 1, flags = RESET_REQUIRED;
      endoneof;

      oneof varid   = NetworkStackVar.Ipv6Pxe,
        prompt      = STRING_TOKEN(STR_IPV6_PXE_BOOT_PROMPT),
        help        = STRING_TOKEN(STR_IPV6_PXE_BOOT_PROMPT_HELP),
        default     = FixedPcdGet8 (PcdIPv6PXESupport),
        option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_ENABLED),  value = 1, flags = RESET_REQUIRED;
      endoneof;

      oneof varid   = NetworkStackVar.Ipv4Http,
        prompt      = STRING_TOKEN(STR_IPV4_HTTP_BOOT_PROMPT),
        help        = STRING_TOKEN(STR_IPV4_HTTP_BOOT_PROMPT_HELP),
        default     = FixedPcdGet8 (PcdIPv4HttpSupport),
        option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_ENABLED),  value = 1, flags = RESET_REQUIRED;
      endoneof;

      oneof varid   = NetworkStackVar.Ipv6Http,
        prompt      = STRING_TOKEN(STR_IPV6_HTTP_BOOT_PROMPT),
        help        = STRING_TOKEN(STR_IPV6_HTTP_BOOT_PROMPT_HELP),
        default     = FixedPcdGet8 (PcdIPv6HttpSupport),
        option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_ENABLED),  value = 1, flags = RESET_REQUIRED;
      endoneof;
endif;
      oneof varid   = PlatformSetupVar.StateAfterG3,
        questionid  = QUESTION_STATE_AFTER_G3_ID,
        prompt      = STRING_TOKEN(STR_RESTORE_AC_POWER_LOSS),
        help        = STRING_TOKEN(STR_RESTORE_AC_POWER_LOSS_HELP),
        flags       = NUMERIC_SIZE_1 | INTERACTIVE | RESET_REQUIRED,
        default     = FixedPcdGet8 (PcdStateAfterG3),
        option text = STRING_TOKEN(STR_S5_AFTER_G3_STRING),        value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_S0_AFTER_G3_STRING),        value = 1, flags = RESET_REQUIRED;
      endoneof;
suppressif TRUE;
      oneof varid   = PlatformSetupVar.DtbMenuEntry,
        prompt      = STRING_TOKEN(STR_DTB_MEMU_ENTRY_PROMPT),
        help        = STRING_TOKEN(STR_DTB_MEMU_ENTRY_PROMPT_HELP),
        option text = STRING_TOKEN(STR_TABLE_0), value = 0, flags = DEFAULT | RESET_REQUIRED;
        option text = STRING_TOKEN(STR_TABLE_1), value = 1, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_TABLE_2), value = 2, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_TABLE_3), value = 3, flags = RESET_REQUIRED;
      endoneof;
endif;
      oneof varid   = PlatformSetupVar.SocWatchdogTimer,
        prompt      = STRING_TOKEN(STR_SOC_WATCH_DOG_TIMER_PROMPT),
        help        = STRING_TOKEN(STR_SOC_WATCH_DOG_TIMER_PROMPT_HELP),
        default     = FixedPcdGet8 (PcdSocWatchdogTimer),
        option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_ENABLED),  value = 1, flags = RESET_REQUIRED;
      endoneof;

      oneof varid   = PlatformSetupVar.RtcWakeup,
        prompt      = STRING_TOKEN(STR_RTC_WAKE_UP_PROMPT),
        help        = STRING_TOKEN(STR_RTC_WAKE_UP_PROMPT_HELP),
        default     = FixedPcdGet8 (PcdRtcWakeup),
        option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_ENABLED),  value = 1, flags = RESET_REQUIRED;
      endoneof;

      oneof varid   = PlatformSetupVar.LightSensorCtrl,
        prompt      = STRING_TOKEN(STR_LIGHT_SENSOR_CONTROL_PROMPT),
        help        = STRING_TOKEN(STR_LIGHT_SENSOR_CONTROL_PROMPT_HELP),
        default     = FixedPcdGet8 (PcdLightSensorCtrl),
        option text = STRING_TOKEN(STR_EC_MODE), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_AP_MODE), value = 1, flags = RESET_REQUIRED;
      endoneof;

      oneof varid   = PlatformSetupVar.SpcrEnable,
        prompt      = STRING_TOKEN(STR_ENABLE_SPCR_TABLE),
        help        = STRING_TOKEN(STR_ENABLE_SPCR_TABLE_HELP),
        default     = FixedPcdGet8 (PcdAcpiSpcrEnable),
        option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_ENABLED), value = 1, flags = RESET_REQUIRED;
      endoneof;

      oneof varid   = PlatformSetupVar.EcFanMode,
        prompt      = STRING_TOKEN(STR_EC_FAN_MODE_PROMPT),
        help        = STRING_TOKEN(STR_EC_FAN_MODE_PROMPT_HELP),
        default     = FixedPcdGet8 (PcdEcDefaultFanMode),
        option text = STRING_TOKEN(STR_AUTO_MODE), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_PERF_MODE), value = 1, flags = RESET_REQUIRED;
      endoneof;
#ifdef DEBUG_MODE_SUPPORT
      oneof varid   = PlatformSetupVar.DebugMode,
        prompt      = STRING_TOKEN(STR_DEBUG_MODE_PROMPT),
        help        = STRING_TOKEN(STR_DEBUG_MODE_HELP),
        default     = 0,
        option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
        option text = STRING_TOKEN(STR_ENABLED), value = 1, flags = RESET_REQUIRED;
      endoneof;
#endif

suppressif ideqval SystemTableVar.SystemTableSelect == 0x01;
      goto DEVICE_POWER_CONTROL_FORM_ID,
        prompt = STRING_TOKEN(STR_DEVICE_POWER_CONTROL_FORM_TITLE),
        help   = STRING_TOKEN(STR_DEVICE_POWER_CONTROL_FORM_TITLE_HELP);
endif;
suppressif TRUE;
      goto CLOCK_GATING_CONTROL_FORM_ID,
        prompt = STRING_TOKEN(STR_CLOCK_GATING_CONTROL_FORM_TITLE),
        help   = STRING_TOKEN(STR_DEVICE_POWER_CONTROL_FORM_TITLE_HELP);
endif;
    endform;

    form formid = DEVICE_POWER_CONTROL_FORM_ID,
