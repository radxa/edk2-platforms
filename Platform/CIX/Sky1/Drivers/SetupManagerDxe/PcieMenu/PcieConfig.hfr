            help        = STRING_TOKEN(STR_LINK_SPEED_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort2SpeedGen),
            option text = STRING_TOKEN(STR_2_5G), value = 1, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_5_0G), value = 2, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_8_0G), value = 3, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_16_0G),value = 4, flags = RESET_REQUIRED;
        endoneof;
endif;
        oneof varid     = PlatformSetupVar.PcieAspmMaxSupport[2],
            prompt      = STRING_TOKEN(STR_PCIE_ASPM_CONFIG_PROMPT),
            help        = STRING_TOKEN(STR_PCIE_ASPM_CONFIG_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort2MaxAspmSupport),
            option text = STRING_TOKEN(STR_PCIE_ASPM_DISABLE),      value = 0, flags = RESET_REQUIRED;
            //option text = STRING_TOKEN(STR_PCIE_ASPM_L0S_STRING),   value = 1, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_PCIE_ASPM_L1_STRING),    value = 2, flags = RESET_REQUIRED;
            //option text = STRING_TOKEN(STR_PCIE_ASPM_L0SL1_STRING), value = 3, flags = RESET_REQUIRED;
        endoneof;
suppressif TRUE;
        oneof varid     = PlatformSetupVar.PcieAspm[2],
            prompt      = STRING_TOKEN(STR_PCIE_ASPM_PROMPT2),
            help        = STRING_TOKEN(STR_PCIE_ASPM_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort2AspmSupport),
            option text = STRING_TOKEN(STR_PCIE_ASPM_DISABLE),      value = 0, flags = RESET_REQUIRED;
            suppressif ideqval PlatformSetupVar.PcieAspmMaxSupport[2] < 0x1;
            option text = STRING_TOKEN(STR_PCIE_ASPM_L0S_STRING),   value = 1, flags = RESET_REQUIRED;
            endif;
            suppressif ideqval PlatformSetupVar.PcieAspmMaxSupport[2] < 0x2;
            option text = STRING_TOKEN(STR_PCIE_ASPM_L1_STRING),    value = 2, flags = RESET_REQUIRED;
            endif;
            suppressif ideqval PlatformSetupVar.PcieAspmMaxSupport[2] < 0x3;
            option text = STRING_TOKEN(STR_PCIE_ASPM_L0SL1_STRING), value = 3, flags = RESET_REQUIRED;
            endif;
        endoneof;
endif;
        oneof varid     = PlatformSetupVar.PcieMaxPayload[2],
            prompt      = STRING_TOKEN(STR_PCIE_MAX_PAYLOAD_PROMPT),
            help        = STRING_TOKEN(STR_PCIE_MAX_PAYLOAD_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort2MaxPayload),
            option text = STRING_TOKEN(STR_MAX_128),  value = 0,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_256),  value = 1,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_512),  value = 2,    flags = RESET_REQUIRED;
        endoneof;
suppressif TRUE;
        oneof varid     = PlatformSetupVar.PcieMaxReadRequest[2],
            prompt      = STRING_TOKEN(STR_PCIE_MAX_READ_REQUEST_PROMPT),
            help        = STRING_TOKEN(STR_PCIE_MAX_READ_REQUEST_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort2MaxReadRequest),
            option text = STRING_TOKEN(STR_MAX_128),  value = 0,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_256),  value = 1,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_512),  value = 2,    flags = RESET_REQUIRED;
