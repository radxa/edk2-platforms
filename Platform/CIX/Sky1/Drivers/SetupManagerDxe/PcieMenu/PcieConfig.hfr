            flags   = DISPLAY_UINT_DEC | NUMERIC_SIZE_2 | INTERACTIVE | RESET_REQUIRED,        // Size of this numeric is 2 byte
            minimum = 300,
            maximum = 1000,                  //1000ms
            step    = 10,
            default = FixedPcdGet16 (PcdPcieRootPort3LinkUpTimeout),
        endnumeric;
endif;
     endform;

    form formid = PCIE_ROOT_PORT4_CONFIG_FORM_ID,
