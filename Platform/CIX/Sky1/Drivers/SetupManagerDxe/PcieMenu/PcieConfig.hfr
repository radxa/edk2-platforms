//PCIE Form
    form formid = PCIE_CONFIG_FORM_ID,
        title  = STRING_TOKEN(STR_PCIE_FORM_SET_TITLE);
        subtitle text = STRING_TOKEN(STR_EMPTY_STRING);

        goto PCIE_ROOT_PORT0_CONFIG_FORM_ID,
           prompt = STRING_TOKEN(STR_PCIERP0_OPTIONS_FORM_TITLE),
           help = STRING_TOKEN(STR_EMPTY_STRING);

        goto PCIE_ROOT_PORT1_CONFIG_FORM_ID,
            prompt = STRING_TOKEN(STR_PCIERP1_OPTIONS_FORM_TITLE),
            help = STRING_TOKEN(STR_EMPTY_STRING);

        goto PCIE_ROOT_PORT2_CONFIG_FORM_ID,
            prompt = STRING_TOKEN(STR_PCIERP2_OPTIONS_FORM_TITLE),
            help = STRING_TOKEN(STR_EMPTY_STRING);

        goto PCIE_ROOT_PORT3_CONFIG_FORM_ID,
            prompt = STRING_TOKEN(STR_PCIERP3_OPTIONS_FORM_TITLE),
            help = STRING_TOKEN(STR_EMPTY_STRING);
        goto PCIE_ROOT_PORT4_CONFIG_FORM_ID,
            prompt = STRING_TOKEN(STR_PCIERP4_OPTIONS_FORM_TITLE),
            help = STRING_TOKEN(STR_EMPTY_STRING);
    endform;

    form formid = PCIE_ROOT_PORT0_CONFIG_FORM_ID,
      title  = STRING_TOKEN(STR_PCIERP0_OPTIONS_FORM_TITLE);
      subtitle text = STRING_TOKEN(STR_EMPTY_STRING);

        oneof varid     = PlatformSetupVar.PcieRpEnable[0],
            prompt      = STRING_TOKEN(STR_PCIE_PROMPT0),
            help        = STRING_TOKEN(STR_PCIERP_HELP),
            default     = FixedPcdGetBool (PcdPcieRootPort0Enable),
            option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_ENABLED),  value = 1, flags = RESET_REQUIRED;
        endoneof;

suppressif ideqval PlatformSetupVar.PcieRpEnable[0] == 0x0;
        oneof varid     =   PlatformSetupVar.PcieWidth[0],
            prompt      =   STRING_TOKEN(STR_PCIE_WIDTH_PROMPT0),
            help        =   STRING_TOKEN(STR_PCIE_WIDTH_HELP),
            default     =   FixedPcdGet8 (PcdPcieRootPort0LaneNum),
            option text =   STRING_TOKEN(STR_X1),  value = 0,  flags = RESET_REQUIRED;
            option text =   STRING_TOKEN(STR_X2),  value = 1,  flags = RESET_REQUIRED;
            option text =   STRING_TOKEN(STR_X4),  value = 2,  flags = RESET_REQUIRED;
            option text =   STRING_TOKEN(STR_X8),  value = 3,  flags = RESET_REQUIRED;
        endoneof;

        oneof varid     = PlatformSetupVar.PcieMaxSpeed[0],
            prompt      = STRING_TOKEN (STR_PCIE_SPEED_PROMPT0),
            help        = STRING_TOKEN (STR_PCIE_SPEED_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort0MaxSpeed),
            option text = STRING_TOKEN (STR_GEN1), value = 0, flags = RESET_REQUIRED;
            option text = STRING_TOKEN (STR_GEN2), value = 1, flags = RESET_REQUIRED;
            option text = STRING_TOKEN (STR_GEN3), value = 2, flags = RESET_REQUIRED;
            option text = STRING_TOKEN (STR_GEN4), value = 3, flags = RESET_REQUIRED;
        endoneof;
suppressif TRUE;
        oneof varid     = PlatformSetupVar.PcieTargetLinkSpeed[0],
            prompt      = STRING_TOKEN(STR_LINK_SPEED_PROMPT),
            help        = STRING_TOKEN(STR_LINK_SPEED_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort0SpeedGen),
            option text = STRING_TOKEN(STR_2_5G), value = 1, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_5_0G), value = 2, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_8_0G), value = 3, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_16_0G),value = 4, flags = RESET_REQUIRED;
        endoneof;
endif;
        oneof varid     = PlatformSetupVar.PcieAspmMaxSupport[0],
            prompt      = STRING_TOKEN(STR_PCIE_ASPM_CONFIG_PROMPT),
            help        = STRING_TOKEN(STR_PCIE_ASPM_CONFIG_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort0MaxAspmSupport),
            option text = STRING_TOKEN(STR_PCIE_ASPM_DISABLE),      value = 0, flags = RESET_REQUIRED;
            //option text = STRING_TOKEN(STR_PCIE_ASPM_L0S_STRING),   value = 1, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_PCIE_ASPM_L1_STRING),    value = 2, flags = RESET_REQUIRED;
            //option text = STRING_TOKEN(STR_PCIE_ASPM_L0SL1_STRING), value = 3, flags = RESET_REQUIRED;
        endoneof;
suppressif TRUE;
        oneof varid     = PlatformSetupVar.PcieAspm[0],
            prompt      = STRING_TOKEN(STR_PCIE_ASPM_PROMPT0),
            help        = STRING_TOKEN(STR_PCIE_ASPM_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort0AspmSupport),
            option text = STRING_TOKEN(STR_PCIE_ASPM_DISABLE),      value = 0, flags = RESET_REQUIRED;
            suppressif ideqval PlatformSetupVar.PcieAspmMaxSupport[0] < 0x1;
            option text = STRING_TOKEN(STR_PCIE_ASPM_L0S_STRING),   value = 1, flags = RESET_REQUIRED;
            endif;
            suppressif ideqval PlatformSetupVar.PcieAspmMaxSupport[0] < 0x2;
            option text = STRING_TOKEN(STR_PCIE_ASPM_L1_STRING),    value = 2, flags = RESET_REQUIRED;
            endif;
            suppressif ideqval PlatformSetupVar.PcieAspmMaxSupport[0] < 0x3;
            option text = STRING_TOKEN(STR_PCIE_ASPM_L0SL1_STRING), value = 3, flags = RESET_REQUIRED;
            endif;
        endoneof;
endif;
        oneof varid     = PlatformSetupVar.PcieMaxPayload[0],
            prompt      = STRING_TOKEN(STR_PCIE_MAX_PAYLOAD_PROMPT),
            help        = STRING_TOKEN(STR_PCIE_MAX_PAYLOAD_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort0MaxPayload),
            option text = STRING_TOKEN(STR_MAX_128),  value = 0,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_256),  value = 1,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_512),  value = 2,    flags = RESET_REQUIRED;
        endoneof;
suppressif TRUE;
        oneof varid     = PlatformSetupVar.PcieMaxReadRequest[0],
            prompt      = STRING_TOKEN(STR_PCIE_MAX_READ_REQUEST_PROMPT),
            help        = STRING_TOKEN(STR_PCIE_MAX_READ_REQUEST_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort0MaxReadRequest),
            option text = STRING_TOKEN(STR_MAX_128),  value = 0,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_256),  value = 1,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_512),  value = 2,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_1024), value = 3,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_2048), value = 4,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_4096), value = 5,    flags = RESET_REQUIRED;
        endoneof;

        oneof varid     = PlatformSetupVar.PcieDtiEnable[0],
            prompt      = STRING_TOKEN(STR_PCIE_DTI_PROMPT),
            help        = STRING_TOKEN(STR_PCIE_DTI_HELP),
            default     = FixedPcdGetBool (PcdPcieRootPort0DtiEnable),
            option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_ENABLED),  value = 1, flags = RESET_REQUIRED;
        endoneof;
endif;
        numeric varid   = PlatformSetupVar.PcieLinkTimeout[0],
            questionid = 0x3000,
            prompt  = STRING_TOKEN(STR_PCIE_LINK_TIMEOUT_PROMPT),
            help    = STRING_TOKEN(STR_PCIE_LINK_TIMEOUT_HELP),
            //
            // Size should be defined for numeric when use Name/Value storage
            // Valid value for numerice size are: NUMERIC_SIZE_1, NUMERIC_SIZE_2, NUMERIC_SIZE_4 and NUMERIC_SIZE_8
            //
            flags   = DISPLAY_UINT_DEC | NUMERIC_SIZE_2 | INTERACTIVE | RESET_REQUIRED,        // Size of this numeric is 2 byte
            minimum = 300,
            maximum = 1000,                  //1000ms
            step    = 10,
            default = FixedPcdGet16 (PcdPcieRootPort0LinkUpTimeout),
        endnumeric;
endif;
     endform;

    form formid = PCIE_ROOT_PORT1_CONFIG_FORM_ID,
      title  = STRING_TOKEN(STR_PCIERP1_OPTIONS_FORM_TITLE);
      subtitle text = STRING_TOKEN(STR_EMPTY_STRING);

        oneof varid     = PlatformSetupVar.PcieRpEnable[1],
            prompt      = STRING_TOKEN(STR_PCIE_PROMPT1),
            help        = STRING_TOKEN(STR_PCIERP_HELP),
            default     = FixedPcdGetBool (PcdPcieRootPort1Enable),
            option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_ENABLED),  value = 1, flags = RESET_REQUIRED;
        endoneof;
suppressif ideqval PlatformSetupVar.PcieRpEnable[1] == 0x0;
        oneof varid     =   PlatformSetupVar.PcieWidth[1],
            prompt      =   STRING_TOKEN(STR_PCIE_WIDTH_PROMPT1),
            help        =   STRING_TOKEN(STR_PCIE_WIDTH_HELP),
            default     =   FixedPcdGet8 (PcdPcieRootPort1LaneNum),
            option text =   STRING_TOKEN(STR_X1),  value = 0,  flags = RESET_REQUIRED;
            option text =   STRING_TOKEN(STR_X2),  value = 1,  flags = RESET_REQUIRED;
            option text =   STRING_TOKEN(STR_X4),  value = 2,  flags = RESET_REQUIRED;
        endoneof;

        oneof varid     = PlatformSetupVar.PcieMaxSpeed[1],
            prompt      = STRING_TOKEN (STR_PCIE_SPEED_PROMPT1),
            help        = STRING_TOKEN (STR_PCIE_SPEED_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort1MaxSpeed),
            option text = STRING_TOKEN (STR_GEN1), value = 0, flags = RESET_REQUIRED;
            option text = STRING_TOKEN (STR_GEN2), value = 1, flags = RESET_REQUIRED;
            option text = STRING_TOKEN (STR_GEN3), value = 2, flags = RESET_REQUIRED;
            option text = STRING_TOKEN (STR_GEN4), value = 3, flags = RESET_REQUIRED;
        endoneof;
suppressif TRUE;
        oneof varid     = PlatformSetupVar.PcieTargetLinkSpeed[1],
            prompt      = STRING_TOKEN(STR_LINK_SPEED_PROMPT),
            help        = STRING_TOKEN(STR_LINK_SPEED_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort1SpeedGen),
            option text = STRING_TOKEN(STR_2_5G), value = 1, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_5_0G), value = 2, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_8_0G), value = 3, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_16_0G),value = 4, flags = RESET_REQUIRED;
        endoneof;
endif;
        oneof varid     = PlatformSetupVar.PcieAspmMaxSupport[1],
            prompt      = STRING_TOKEN(STR_PCIE_ASPM_CONFIG_PROMPT),
            help        = STRING_TOKEN(STR_PCIE_ASPM_CONFIG_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort1MaxAspmSupport),
            option text = STRING_TOKEN(STR_PCIE_ASPM_DISABLE),      value = 0, flags = RESET_REQUIRED;
            //option text = STRING_TOKEN(STR_PCIE_ASPM_L0S_STRING),   value = 1, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_PCIE_ASPM_L1_STRING),    value = 2, flags = RESET_REQUIRED;
            //option text = STRING_TOKEN(STR_PCIE_ASPM_L0SL1_STRING), value = 3, flags = RESET_REQUIRED;
        endoneof;
suppressif TRUE;
        oneof varid     = PlatformSetupVar.PcieAspm[1],
            prompt      = STRING_TOKEN(STR_PCIE_ASPM_PROMPT1),
            help        = STRING_TOKEN(STR_PCIE_ASPM_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort1AspmSupport),
            option text = STRING_TOKEN(STR_PCIE_ASPM_DISABLE),      value = 0, flags = RESET_REQUIRED;
            suppressif ideqval PlatformSetupVar.PcieAspmMaxSupport[1] < 0x1;
            option text = STRING_TOKEN(STR_PCIE_ASPM_L0S_STRING),   value = 1, flags = RESET_REQUIRED;
            endif;
            suppressif ideqval PlatformSetupVar.PcieAspmMaxSupport[1] < 0x2;
            option text = STRING_TOKEN(STR_PCIE_ASPM_L1_STRING),    value = 2, flags = RESET_REQUIRED;
            endif;
            suppressif ideqval PlatformSetupVar.PcieAspmMaxSupport[1] < 0x3;
            option text = STRING_TOKEN(STR_PCIE_ASPM_L0SL1_STRING), value = 3, flags = RESET_REQUIRED;
            endif;
        endoneof;
endif;
        oneof varid     = PlatformSetupVar.PcieMaxPayload[1],
            prompt      = STRING_TOKEN(STR_PCIE_MAX_PAYLOAD_PROMPT),
            help        = STRING_TOKEN(STR_PCIE_MAX_PAYLOAD_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort1MaxPayload),
            option text = STRING_TOKEN(STR_MAX_128),  value = 0,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_256),  value = 1,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_512),  value = 2,    flags = RESET_REQUIRED;
        endoneof;
suppressif TRUE;
        oneof varid     = PlatformSetupVar.PcieMaxReadRequest[1],
            prompt      = STRING_TOKEN(STR_PCIE_MAX_READ_REQUEST_PROMPT),
            help        = STRING_TOKEN(STR_PCIE_MAX_READ_REQUEST_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort1MaxReadRequest),
            option text = STRING_TOKEN(STR_MAX_128),  value = 0,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_256),  value = 1,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_512),  value = 2,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_1024), value = 3,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_2048), value = 4,    flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_MAX_4096), value = 5,    flags = RESET_REQUIRED;
        endoneof;

        oneof varid     = PlatformSetupVar.PcieDtiEnable[1],
            prompt      = STRING_TOKEN(STR_PCIE_DTI_PROMPT),
            help        = STRING_TOKEN(STR_PCIE_DTI_HELP),
            default     = FixedPcdGetBool (PcdPcieRootPort1DtiEnable),
            option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_ENABLED),  value = 1, flags = RESET_REQUIRED;
        endoneof;
endif;
        numeric varid   = PlatformSetupVar.PcieLinkTimeout[1],
            questionid = 0x3001,
            prompt  = STRING_TOKEN(STR_PCIE_LINK_TIMEOUT_PROMPT),
            help    = STRING_TOKEN(STR_PCIE_LINK_TIMEOUT_HELP),
            //
            // Size should be defined for numeric when use Name/Value storage
            // Valid value for numerice size are: NUMERIC_SIZE_1, NUMERIC_SIZE_2, NUMERIC_SIZE_4 and NUMERIC_SIZE_8
            //
            flags   = DISPLAY_UINT_DEC | NUMERIC_SIZE_2 | INTERACTIVE | RESET_REQUIRED,        // Size of this numeric is 2 byte
            minimum = 300,
            maximum = 1000,                  //1000ms
            step    = 10,
            default = FixedPcdGet16 (PcdPcieRootPort1LinkUpTimeout),
        endnumeric;
endif;
     endform;

    form formid = PCIE_ROOT_PORT2_CONFIG_FORM_ID,
      title  = STRING_TOKEN(STR_PCIERP2_OPTIONS_FORM_TITLE);
      subtitle text = STRING_TOKEN(STR_EMPTY_STRING);

        oneof varid     = PlatformSetupVar.PcieRpEnable[2],
            prompt      = STRING_TOKEN(STR_PCIE_PROMPT2),
            help        = STRING_TOKEN(STR_PCIERP_HELP),
            default     = FixedPcdGetBool (PcdPcieRootPort2Enable),
            option text = STRING_TOKEN(STR_DISABLED), value = 0, flags = RESET_REQUIRED;
            option text = STRING_TOKEN(STR_ENABLED),  value = 1, flags = RESET_REQUIRED;
        endoneof;
suppressif ideqval PlatformSetupVar.PcieRpEnable[2] == 0x0;
        oneof varid     =   PlatformSetupVar.PcieWidth[2],
            prompt      =   STRING_TOKEN(STR_PCIE_WIDTH_PROMPT2),
            help        =   STRING_TOKEN(STR_PCIE_WIDTH_HELP),
            default     =   FixedPcdGet8 (PcdPcieRootPort2LaneNum),
            option text =   STRING_TOKEN(STR_X1),  value = 0,  flags = RESET_REQUIRED;
            option text =   STRING_TOKEN(STR_X2),  value = 1,  flags = RESET_REQUIRED;
        endoneof;

        oneof varid     = PlatformSetupVar.PcieMaxSpeed[2],
            prompt      = STRING_TOKEN (STR_PCIE_SPEED_PROMPT2),
            help        = STRING_TOKEN (STR_PCIE_SPEED_HELP),
            default     = FixedPcdGet8 (PcdPcieRootPort2MaxSpeed),
            option text = STRING_TOKEN (STR_GEN1), value = 0, flags = RESET_REQUIRED;
            option text = STRING_TOKEN (STR_GEN2), value = 1, flags = RESET_REQUIRED;
            option text = STRING_TOKEN (STR_GEN3), value = 2, flags = RESET_REQUIRED;
            option text = STRING_TOKEN (STR_GEN4), value = 3, flags = RESET_REQUIRED;
        endoneof;
suppressif TRUE;
        oneof varid     = PlatformSetupVar.PcieTargetLinkSpeed[2],
